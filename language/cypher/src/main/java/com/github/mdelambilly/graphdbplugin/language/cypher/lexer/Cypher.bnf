                | K_ENDS
                | K_END
                | K_ELSE
                | K_DROP
                | K_DO
                | K_DISTINCT
                | K_DETACH
                | K_DESCENDING
                | K_DESC
                | K_DELETE
                | K_CYPHER
                | K_CSV
                | K_CREATE
                | K_COUNT
                | K_CONTAINS
                | K_CONSTRAINT
                | K_COMMIT
                | K_CASE
                | K_CALL
                | K_BY
                | K_BEGIN
                | K_ASSERT
                | K_ASCENDING
                | K_ASC
                | K_AS
                | K_ANY
                | K_AND
                | K_ALLSHORTESTPATHS
                | K_ALL
                | K_ADD
                // Phase 1 keywords (same exclusions apply)
                | K_ACCESS
                | K_ACTIVE
                | K_ADMIN
                | K_ADMINISTRATOR
                | K_ALTER
                | K_ASSIGN
                | K_BOOSTED
                | K_BRIEF
                | K_BTREE
                | K_CATALOG
                | K_CHANGE
                | K_COLLECT
                | K_CONSTRAINTS
                | K_COPY
                | K_CURRENT
                | K_DATABASE
                | K_DATABASES
                | K_DBMS
                | K_DEFAULT
                | K_DEFINED
                | K_DENY
                | K_ELEMENT
                | K_ELEMENTS
                | K_EXECUTE
                | K_EXIST
                | K_FUNCTION
                | K_FUNCTIONS
                | K_GRANT
