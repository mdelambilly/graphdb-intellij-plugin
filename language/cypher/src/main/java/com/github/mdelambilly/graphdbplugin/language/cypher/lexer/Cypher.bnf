/**
 * Copied and adapted from plugin
 * <a href="https://github.com/neueda/jetbrains-plugin-graph-database-support">Graph Database Support</a>
 * by Neueda Technologies, Ltd.
 * Modified by Alberto Venturini, 2022
 * Modified by Michel de Lambilly, 2026
 */
{
  parserClass="com.github.mdelambilly.graphdbplugin.language.cypher.CypherParser"

  extends="com.intellij.extapi.psi.ASTWrapperPsiElement"

  elementTypeHolderClass="com.github.mdelambilly.graphdbplugin.language.cypher.psi.CypherTypes"
  elementTypeClass="com.github.mdelambilly.graphdbplugin.language.cypher.psi.CypherElementType"
  tokenTypeClass="com.github.mdelambilly.graphdbplugin.language.cypher.psi.CypherTokenType"

  psiImplUtilClass="com.github.mdelambilly.graphdbplugin.language.cypher.psi.CypherPsiImplUtil"
  psiClassPrefix="Cypher"
  psiImplClassSuffix="Impl"
  psiPackage="com.github.mdelambilly.graphdbplugin.language.cypher.psi"
  psiImplPackage="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl"

  tokens=[
    // base
    semicolon=";"
    parenthesis_open="("
    parenthesis_close=")"
    bracket_CurlyOpen="{"
    bracket_CurlyClose="}"
    bracket_SquareOpen="["
    bracket_SquareClose="]"
    dollar="$"
    op_colon=":"
    op_dot="."
    op_equal="="
    op_lessThen="<"
    op_greatherThen=">"
    op_plus="+"
    op_minus="-"
    op_mul="*"
    op_bactick="`"
    op_comma=","
    op_questionSign="?"
    op_pipe="|"
    op_range=".."
    op_plusEquals="+="
    op_invalidNotEquals="<>"
    op_notEquals="!="
    op_lessThanEquals="<="
    op_greaterThanEquals=">="
    op_divide="/"
    op_modulo="%"
    op_pow="^"
    op_regexMatch="=~"
    op_ampersand="&"
    op_exclamation="!"
    op_coloncolon="::"
  ]
}

cypher ::= StatementItem *

StatementItem ::= !<<eof>> Statement ';'? {pin=1 recoverWhile=statement_recover}
private statement_recover::= !(';'
                        | K_USE
                        | K_USING
                        | K_UNION
                        | K_LOAD
                        | K_START
                        | K_MATCH
                        | K_UNWIND
                        | K_MERGE
                        | K_CREATE
                        | K_CREATE_INDEX
                        | K_CREATE_RANGE_INDEX
                        | K_CREATE_LOOKUP_INDEX
                        | K_CREATE_POINT_INDEX
                        | K_CREATE_TEXT_INDEX
                        | K_DROP
                        | K_SET
                        | K_DELETE
                        | K_REMOVE
                        | K_FOREACH
                        | K_WITH
                        | K_RETURN
                        | K_BEGIN
                        | K_COMMIT
                        | K_CYPHER
                        | K_PROFILE
                        | K_EXPLAIN
                        | K_CALL
                        | K_OPTIONAL| K_DETACH
                        | K_SHOW
                        | K_STOP
                        | K_ALTER
                        | K_GRANT
                        | K_DENY
                        | K_REVOKE
                        | K_ENABLE
                        | K_TERMINATE
                        | K_RENAME
                        | K_DRYRUN
                        | K_DEALLOCATE
                        | K_REALLOCATE
                        | "}")

/*************************
 * Statement
 */
Statement ::= (K_BEGIN) | (K_COMMIT) | SystemCommand | (QueryOptions? (Command | Query))

/*************************
 * Statement options
 */
QueryOptions ::= AnyCypherOption*
AnyCypherOption ::= CypherOption | Explain | Profile;
CypherOption ::= K_CYPHER VersionNumber? ConfigurationOption*
VersionNumber ::= DoubleLiteral
Explain ::= K_EXPLAIN
Profile ::= K_PROFILE
ConfigurationOption ::= SymbolicNameString '=' SymbolicNameString

/*************************
 * Command
 */
Command ::= CreateIndex
          | DropIndex
          | CreateUniqueConstraint
          | DropUniqueConstraint
          | CreateNodeKeyConstraint
          | DropNodeKeyConstraint
          | CreateNodePropertyExistenceConstraint
          | DropNodePropertyExistenceConstraint
          | CreateRelationshipPropertyExistenceConstraint
          | DropRelationshipPropertyExistenceConstraint
          | CreateConstraint
          | DropConstraint

CreateUniqueConstraint ::= K_CREATE UniqueConstraintSyntax
DropUniqueConstraint ::= K_DROP UniqueConstraintSyntax
UniqueConstraintSyntax ::= K_CONSTRAINT K_ON "(" Variable NodeLabel ")" K_ASSERT PropertyExpression K_IS K_UNIQUE

CreateNodePropertyExistenceConstraint ::= K_CREATE NodePropertyExistenceConstraintSyntax
DropNodePropertyExistenceConstraint ::= K_DROP NodePropertyExistenceConstraintSyntax
NodePropertyExistenceConstraintSyntax ::= K_CONSTRAINT K_ON "(" Variable NodeLabel ")" K_ASSERT K_EXISTS "(" PropertyExpression ")"

CreateRelationshipPropertyExistenceConstraint ::= K_CREATE RelationshipPropertyExistenceConstraintSyntax
DropRelationshipPropertyExistenceConstraint ::= K_DROP RelationshipPropertyExistenceConstraintSyntax
RelationshipPropertyExistenceConstraintSyntax ::= K_CONSTRAINT K_ON RelationshipPatternSyntax K_ASSERT K_EXISTS "(" PropertyExpression ")"
RelationshipPatternSyntax ::= ("(" ")" "-" "[" Variable RelType "]" "-" "(" ")")
      | ("(" ")" "-" "[" Variable RelType "]" "-" ">" "(" ")")
      | ("(" ")" "<" "-" "[" Variable RelType "]" "-" "(" ")")
CreateNodeKeyConstraint ::= K_CREATE NodeKeyConstraintSyntax
DropNodeKeyConstraint ::= K_DROP NodeKeyConstraintSyntax
NodeKeyConstraintSyntax ::= K_CONSTRAINT K_ON "(" Variable NodeLabel ")" K_ASSERT "(" PropertyExpression ("," PropertyExpression)* ")" K_IS K_NODE K_KEY

/*************************
 * Modern Constraint Syntax (Neo4j 4.4+)
 *
 * Supports named/unnamed constraints, IF NOT EXISTS, FOR/REQUIRE patterns,
 * and all predicate kinds: IS UNIQUE, IS KEY, IS NODE KEY, IS REL KEY,
 * IS NOT NULL, IS TYPED <type>, IS :: <type>.
 *
 * Legacy ASSERT-based rules above are kept for backward compatibility.
 * New rules are listed AFTER legacy rules in Command so legacy syntax
 * takes priority during PEG matching.
 */

// CREATE [OR REPLACE] CONSTRAINT [name] [IF NOT EXISTS] FOR (...) REQUIRE ...
// ConstraintName uses a negative lookahead to avoid consuming FOR or IF NOT EXISTS
// as a constraint name when the name is omitted.
CreateConstraint ::= K_CREATE OrReplace? K_CONSTRAINT ConstraintName? IfNotExists?
                     ConstraintBody {pin=3}

ConstraintName ::= !(K_FOR | K_IF_NOT_EXISTS) SymbolicNameString

private ConstraintBody ::= ConstraintForNode | ConstraintForRelationship

// FOR (n:Label) REQUIRE n.prop IS ...
private ConstraintForNode ::= K_FOR "(" Variable NodeLabel ")" K_REQUIRE ConstraintRequire

// FOR ()-[r:TYPE]-() REQUIRE r.prop IS ...
private ConstraintForRelationship ::= K_FOR "(" ")" "-" "[" Variable RelType "]" "-" "(" ")" K_REQUIRE ConstraintRequire

// The requirement predicate and its type annotation
ConstraintRequire ::= PropertyExpression ConstraintPredicate

private ConstraintPredicate ::= K_IS K_NODE K_KEY
                               | K_IS K_REL K_KEY
                               | K_IS K_UNIQUE
                               | K_IS K_KEY
                               | K_IS K_NOT K_NULL
                               | K_IS K_TYPED CypherTypeName
                               | K_IS "::" CypherTypeName

// Property type name for IS TYPED / IS :: constraints.
// Handles: BOOLEAN, STRING, INTEGER, LIST<STRING>, etc. (via SymbolicNameString)
// Optionally followed by NOT NULL to indicate a non-nullable type.
CypherTypeName ::= SymbolicNameString ("<" SymbolicNameString ">")? (K_NOT K_NULL)?

// DROP CONSTRAINT name [IF EXISTS]
DropConstraint ::= K_DROP K_CONSTRAINT ConstraintName IfExists? {pin=2}

/*************************
 * System Commands
 */
SystemCommand ::= ShowCommand
               | MultidatabaseCommand
               | UserCommand
               | RoleCommand
               | PrivilegeCommand
               | AllocationCommand
               | TerminateCommand
               | RenameCommand

ShowCommand ::= K_SHOW ShowBody {pin=1}

private ShowBody ::= ShowDatabase ShowTail?
                   | ShowIndexes ShowTail?
                   | ShowConstraints ShowTail?
                   | ShowProcedures ShowTail?
                   | ShowFunctions ShowTail?
                   | ShowCurrentUser ShowTail?
                   | ShowTransactions ShowTail?
                   | ShowUsers ShowTail?
                   | ShowRoles ShowTail?
                   | ShowPrivileges ShowTail?
                   | ShowAliases ShowTail?
                   | ShowServers ShowTail?

private ShowTail ::= YieldClause Return? | Where

MultidatabaseCommand ::= CreateCompositeDatabase
                       | CreateDatabase
                       | CreateAlias
                       | AlterDatabase
                       | AlterAlias
                       | AlterServer
                       | DropDatabase
                       | DropAlias
                       | DropServer
                       | StartDatabase
                       | StopDatabase
                       | EnableServerCommand

ShowDatabase ::= K_DATABASES | (K_DEFAULT K_DATABASE) | (K_DATABASE SymbolicNameString)
CreateCompositeDatabase ::= K_CREATE K_COMPOSITE K_DATABASE SymbolicAliasName IfNotExists? Options? WaitClause? {pin=3}
CreateDatabase ::= K_CREATE OrReplace? K_DATABASE SymbolicAliasName IfNotExists?
                   (K_TOPOLOGY (UnsignedInteger (K_PRIMARY | K_PRIMARIES | K_SECONDARY | K_SECONDARIES))+)?
                   Options? WaitClause? {pin=3}
DropDatabase ::= K_DROP K_COMPOSITE? K_DATABASE SymbolicAliasName IfExists? ((K_DUMP | K_DESTROY) K_DATA)? WaitClause? {pin=3}
StartDatabase ::= K_START K_DATABASE SymbolicAliasName WaitClause? {pin=2}
StopDatabase ::= K_STOP K_DATABASE SymbolicAliasName WaitClause? {pin=2}
AlterDatabase ::= K_ALTER K_DATABASE SymbolicAliasName IfExists?
                  ((K_SET AlterDatabaseOption)+ | (K_REMOVE K_OPTION SymbolicNameString)+)
                  WaitClause? {pin=2}
private AlterDatabaseOption ::= K_ACCESS K_READ (K_ONLY | K_WRITE)
                               | K_TOPOLOGY (UnsignedInteger (K_PRIMARY | K_PRIMARIES | K_SECONDARY | K_SECONDARIES))+
                               | K_OPTION SymbolicNameString Expression
WaitClause ::= K_WAIT (UnsignedInteger (K_SEC | K_SECOND | K_SECONDS)?)? | K_NOWAIT
Options ::= K_OPTIONS (MapLiteral | Parameter)
StringOrParameter ::= StringLiteral | Parameter
PasswordExpression ::= StringLiteral | Parameter
CreateAlias ::= K_CREATE K_ALIAS SymbolicAliasName IfNotExists? K_FOR K_DATABASE SymbolicAliasName
                (K_AT StringOrParameter K_USER SymbolicNameOrStringParameter K_PASSWORD PasswordExpression (K_DRIVER (MapLiteral | Parameter))?)?
                (K_PROPERTIES (MapLiteral | Parameter))? {pin=2}
DropAlias ::= K_DROP K_ALIAS SymbolicAliasName IfExists? K_FOR K_DATABASE {pin=2}
AlterAlias ::= K_ALTER K_ALIAS SymbolicAliasName IfExists? K_SET K_DATABASE AlterAliasOption+ {pin=2}
private AlterAliasOption ::= K_TARGET SymbolicAliasName (K_AT StringOrParameter)?
                            | K_USER SymbolicNameOrStringParameter
                            | K_PASSWORD PasswordExpression
                            | K_DRIVER (MapLiteral | Parameter)
                            | K_PROPERTIES (MapLiteral | Parameter)

UserCommand ::= CreateUser
              | DropUser
              | AlterUser

ShowUsers ::= K_USERS
CreateUser ::= K_CREATE OrReplace? K_USER SymbolicNameString IfNotExists? SetPassword SetStatus? {pin=3}
DropUser ::= K_DROP K_USER SymbolicNameString IfExists? {pin=2}
AlterUser ::= K_ALTER K_CURRENT? K_USER SymbolicNameString? (SetPassword | SetStatus)+ {pin=3}

SetPassword ::= K_SET K_PASSWORD (StringLiteral | Parameter) PasswordStatus?
SetStatus ::= K_SET K_STATUS UserStatus
UserStatus ::= K_ACTIVE | K_SUSPENDED
PasswordStatus ::= K_CHANGE (K_NOT)? K_REQUIRED

RoleCommand ::= CreateRole
              | DropRole

ShowRoles ::= K_ALL K_ROLES (K_WITH K_USERS)?
            | K_POPULATED K_ROLES (K_WITH K_USERS)?
            | K_ROLES (K_WITH K_USERS)?
CreateRole ::= K_CREATE OrReplace? K_ROLE SymbolicNameString IfNotExists? (K_AS K_COPY K_OF SymbolicNameString)? {pin=3}
DropRole ::= K_DROP K_ROLE SymbolicNameString IfExists? {pin=2}

PrivilegeCommand ::= GrantCommand
                   | DenyCommand
                   | RevokeCommand

ShowPrivileges ::= K_ALL K_PRIVILEGES
                 | K_ROLE SymbolicNameString K_PRIVILEGES
                 | K_USER SymbolicNameString? K_PRIVILEGES

ShowIndexes ::= K_INDEXES | K_INDEX
ShowConstraints ::= K_CONSTRAINTS | K_CONSTRAINT
ShowProcedures ::= K_PROCEDURES | K_PROCEDURE
ShowFunctions ::= K_FUNCTIONS | K_FUNCTION
ShowCurrentUser ::= K_CURRENT K_USER
ShowTransactions ::= K_TRANSACTIONS | K_TRANSACTION
ShowAliases ::= (K_ALIAS | K_ALIASES) ShowAliasName? K_FOR (K_DATABASE | K_DATABASES)
private ShowAliasName ::= !(K_FOR) SymbolicAliasName

//-- Phase K: server management commands
ShowServers ::= K_SERVERS | K_SERVER
EnableServerCommand ::= K_ENABLE K_SERVER StringOrParameter Options? {pin=1}
AlterServer ::= K_ALTER K_SERVER StringOrParameter K_SET Options {pin=2}
DropServer ::= K_DROP K_SERVER StringOrParameter {pin=2}

AllocationCommand ::= K_DRYRUN? (DeallocateDatabaseFromServers | ReallocateDatabases)
DeallocateDatabaseFromServers ::= K_DEALLOCATE (K_DATABASE | K_DATABASES) K_FROM (K_SERVER | K_SERVERS) StringOrParameter ("," StringOrParameter)* {pin=1}
ReallocateDatabases ::= K_REALLOCATE (K_DATABASE | K_DATABASES) {pin=1}

TerminateCommand ::= K_TERMINATE K_TRANSACTIONS (StringOrParameter ("," StringOrParameter)*)? ShowTail? {pin=1}

RenameCommand ::= K_RENAME (RenameRole | RenameUser | RenameServer) {pin=1}
RenameRole ::= K_ROLE SymbolicNameOrStringParameter IfExists? K_TO SymbolicNameOrStringParameter
RenameUser ::= K_USER SymbolicNameOrStringParameter IfExists? K_TO SymbolicNameOrStringParameter
RenameServer ::= K_SERVER StringOrParameter K_TO StringOrParameter

//-- YIELD clause (SHOW commands, Neo4j 4.4+)
YieldClause ::= K_YIELD ("*" | YieldItem ("," YieldItem)*) Order? Skip? Limit? Where?
YieldItem ::= Variable (K_AS Variable)?

//-- GRANT / DENY / REVOKE commands (Phase H — full GPM privilege model)
GrantCommand ::= K_GRANT (K_IMMUTABLE? GrantPrivilege | K_ROLE (GrantRoleManagement | GrantRole) | K_ROLES GrantRole | K_IMMUTABLE K_ROLE GrantRoleManagement) {pin=1}
DenyCommand ::= K_DENY K_IMMUTABLE? (DenyPrivilege | K_ROLE RoleManagementPrivilege K_TO SymbolicNameOrStringParameterList) {pin=1}
RevokeCommand ::= K_REVOKE (K_DENY K_IMMUTABLE? | K_GRANT K_IMMUTABLE? | K_IMMUTABLE)? (RevokePrivilege | K_ROLE (RevokeRoleManagement | RevokeRole) | K_ROLES RevokeRole) {pin=1}

GrantPrivilege ::= Privilege K_TO SymbolicNameOrStringParameterList
DenyPrivilege ::= Privilege K_TO SymbolicNameOrStringParameterList
RevokePrivilege ::= Privilege K_FROM SymbolicNameOrStringParameterList

GrantRole ::= SymbolicNameOrStringParameterList K_TO SymbolicNameOrStringParameterList
RevokeRole ::= SymbolicNameOrStringParameterList K_FROM SymbolicNameOrStringParameterList
GrantRoleManagement ::= RoleManagementPrivilege K_TO SymbolicNameOrStringParameterList
RevokeRoleManagement ::= RoleManagementPrivilege K_FROM SymbolicNameOrStringParameterList
RoleManagementPrivilege ::= K_MANAGEMENT K_ON K_DBMS

// Kept for backward compatibility (PSI stability)
Roles ::= SymbolicNameString ("," SymbolicNameString)*

Privilege ::= AllPrivilege
            | CreatePrivilege
            | DropPrivilege
            | ShowPrivilege
            | SetPrivilege
            | RemovePrivilege
            | DatabasePrivilege
            | DbmsPrivilege
            | WritePrivilege
            | QualifiedGraphPrivilegesWithProperty
            | QualifiedGraphPrivileges

AllPrivilege ::= K_ALL AllPrivilegeType? K_ON AllPrivilegeTarget
AllPrivilegeType ::= (K_DBMS | K_GRAPH | K_DATABASE)? K_PRIVILEGES
AllPrivilegeTarget ::= K_DEFAULT (K_GRAPH | K_DATABASE)
                     | K_HOME (K_GRAPH | K_DATABASE)
                     | K_DBMS
                     | GraphScopeList
                     | DatabaseScopeList

// Note: "CREATE INDEX" is lexed as compound token K_CREATE_INDEX; "CREATE INDEXES" uses K_CREATE + K_INDEXES
CreatePrivilege ::= K_CREATE_INDEX K_ON DatabaseScopeList
                  | K_CREATE ((K_INDEXES | K_CONSTRAINT | K_CONSTRAINTS
                               | K_NEW (K_NODE? (K_LABEL | K_LABELS) | K_RELATIONSHIP? (K_TYPE | K_TYPES) | K_PROPERTY? (K_NAME | K_NAMES))
                               ) K_ON DatabaseScopeList
                             | (K_DATABASE | K_ALIAS | K_ROLE | K_USER | K_COMPOSITE K_DATABASE) K_ON K_DBMS
                             | K_ON GraphScopeList GraphQualifier?)

DropPrivilege ::= K_DROP (((K_INDEX | K_INDEXES) | (K_CONSTRAINT | K_CONSTRAINTS)) K_ON DatabaseScopeList
                         | (K_DATABASE | K_ALIAS | K_ROLE | K_USER | K_COMPOSITE K_DATABASE) K_ON K_DBMS)

ShowPrivilege ::= K_SHOW (((K_INDEX | K_INDEXES) | (K_CONSTRAINT | K_CONSTRAINTS)
                           | (K_TRANSACTION | K_TRANSACTIONS) ("(" ("*" | SymbolicNameOrStringParameterList) ")")?
                           ) K_ON DatabaseScopeList
                          | (K_ALIAS | K_PRIVILEGE | K_ROLE | K_USER | (K_SERVER | K_SERVERS) | (K_SETTING | K_SETTINGS) SettingQualifier?) K_ON K_DBMS)

SetPrivilege ::= K_SET (((K_PASSWORD | K_PASSWORDS) | K_USER (K_STATUS | K_HOME K_DATABASE) | K_DATABASE K_ACCESS) K_ON K_DBMS
                       | K_LABEL LabelResource K_ON GraphScopeList
                       | K_PROPERTY PropertyResource K_ON GraphScopeList GraphQualifier?)

RemovePrivilege ::= K_REMOVE ((K_PRIVILEGE | K_ROLE) K_ON K_DBMS | K_LABEL LabelResource K_ON GraphScopeList)

WritePrivilege ::= K_WRITE K_ON GraphScopeList

DatabasePrivilege ::= (K_ACCESS | K_START | K_STOP
                       | (K_INDEX | K_INDEXES) K_MANAGEMENT?
                       | (K_CONSTRAINT | K_CONSTRAINTS) K_MANAGEMENT?
                       | K_TRANSACTION K_MANAGEMENT? ("(" ("*" | SymbolicNameOrStringParameterList) ")")?
                       | K_TERMINATE (K_TRANSACTION | K_TRANSACTIONS) ("(" ("*" | SymbolicNameOrStringParameterList) ")")?
                       | K_NAME K_MANAGEMENT?) K_ON DatabaseScopeList

DbmsPrivilege ::= (K_ALTER (K_USER | K_DATABASE | K_ALIAS)
                  | K_ASSIGN (K_PRIVILEGE | K_ROLE)
                  | K_COMPOSITE K_DATABASE K_MANAGEMENT
                  | K_DATABASE K_MANAGEMENT
                  | K_ALIAS K_MANAGEMENT
                  | K_EXECUTE ExecuteQualifier
                  | K_PRIVILEGE K_MANAGEMENT
                  | K_RENAME (K_ROLE | K_USER)
                  | K_SERVER K_MANAGEMENT
                  | K_USER K_MANAGEMENT
                  | K_IMPERSONATE ("(" ("*" | SymbolicNameOrStringParameterList) ")")?
                  ) K_ON K_DBMS

// PEG order: PROCEDURE/PROCEDURES before FUNCTION/FUNCTIONS to disambiguate BOOSTED
ExecuteQualifier ::= (K_ADMIN | K_ADMINISTRATOR)? K_BOOSTED? (K_PROCEDURE | K_PROCEDURES) Globs?
                   | (K_ADMIN | K_ADMINISTRATOR)? K_BOOSTED? K_USER? K_DEFINED? (K_FUNCTION | K_FUNCTIONS) Globs?

QualifiedGraphPrivilegesWithProperty ::= (K_TRAVERSE | K_READ PropertyResource | K_MATCH PropertyResource) K_ON GraphScopeList GraphQualifier?
QualifiedGraphPrivileges ::= (K_DELETE | K_MERGE PropertyResource) K_ON GraphScopeList GraphQualifier?

DatabaseScopeList ::= (K_DATABASE | K_DATABASES) ("*" | SymbolicAliasNameList)
                    | K_DEFAULT K_DATABASE
                    | K_HOME K_DATABASE
GraphScopeList ::= (K_GRAPH | K_GRAPHS) ("*" | SymbolicAliasNameList)
                 | K_DEFAULT K_GRAPH
                 | K_HOME K_GRAPH

// Optional: present only when RELATIONSHIP/NODE/ELEMENT qualifier follows
GraphQualifier ::= (K_RELATIONSHIP | K_RELATIONSHIPS) ("*" | SymbolicNameString ("," SymbolicNameString)*)
                 | (K_NODE | K_NODES) ("*" | SymbolicNameString ("," SymbolicNameString)*)
                 | (K_ELEMENT | K_ELEMENTS) ("*" | SymbolicNameString ("," SymbolicNameString)*)

PropertyResource ::= "{" ("*" | SymbolicNameString ("," SymbolicNameString)*) "}"
LabelResource ::= "*" | SymbolicNameString ("," SymbolicNameString)*
SettingQualifier ::= Globs
Globs ::= Glob ("," Glob)*
Glob ::= GlobPart ("." GlobPart)*
GlobPart ::= SymbolicNameString | "*"

SymbolicAliasNameList ::= SymbolicAliasName ("," SymbolicAliasName)*
SymbolicAliasName ::= SymbolicNameString ("." SymbolicNameString)* | Parameter
SymbolicNameOrStringParameterList ::= SymbolicNameOrStringParameter ("," SymbolicNameOrStringParameter)*
SymbolicNameOrStringParameter ::= SymbolicNameString | Parameter

// Kept for backward compatibility (PSI stability)
PropertiesList ::= "*" | (SymbolicNameString ("," SymbolicNameString)*)

IfExists ::= K_IF_EXISTS
IfNotExists ::= K_IF_NOT_EXISTS
OrReplace ::= K_OR K_REPLACE

/*************************
 * Indexes
 */

CreateIndex ::= CreateRangeIndex
              | CreateTextIndex
              | CreatePointIndex
              | CreateLookupIndex

CreateRangeIndex ::= CreateNamedRangeIndex | CreateUnnamedRangeIndex
private CreateNamedRangeIndex ::= (K_CREATE_INDEX | K_CREATE_RANGE_INDEX) IndexName CreateIndexBody
private CreateUnnamedRangeIndex ::= (K_CREATE_INDEX | K_CREATE_RANGE_INDEX) CreateIndexBody

CreateTextIndex ::= CreateNamedTextIndex | CreateUnnamedTextIndex
private CreateNamedTextIndex ::= K_CREATE_TEXT_INDEX IndexName CreateIndexBody
private CreateUnnamedTextIndex ::= K_CREATE_TEXT_INDEX CreateIndexBody

CreatePointIndex ::= CreateNamedPointIndex | CreateUnnamedPointIndex
private CreateNamedPointIndex ::= K_CREATE_POINT_INDEX IndexName CreateIndexBody
private CreateUnnamedPointIndex ::= K_CREATE_POINT_INDEX CreateIndexBody

IndexName ::= SymbolicNameString

private CreateIndexBody ::= K_IF_NOT_EXISTS? CreateIndexForPart CreateIndexOnPropertiesPart CreateIndexOptionsPart?

private CreateIndexForPart ::= K_FOR (CreateIndexForNodePart | CreateIndexForRelationshipPart)
CreateIndexForNodePart ::= "(" Variable NodeLabel ")"
CreateIndexForRelationshipPart ::= "(" ")" "-" "[" Variable RelType "]" "-" "(" ")"

CreateIndexOnPropertiesPart ::= K_ON "(" Variable "." PropertyKeyName ("," Variable "." PropertyKeyName)* ")"

// CREATE LOOKUP INDEX is a little different, so it is handled separately
CreateLookupIndex ::= CreateNamedLookupIndex | CreateUnnamedLookupIndex
private CreateNamedLookupIndex ::= K_CREATE_LOOKUP_INDEX IndexName CreateLookupIndexBody
private CreateUnnamedLookupIndex ::= K_CREATE_LOOKUP_INDEX CreateLookupIndexBody

private CreateLookupIndexBody ::= K_IF_NOT_EXISTS? (CreateLookupIndexForNodePart | CreateLookupIndexForRelationshipPart) CreateIndexOptionsPart?
CreateLookupIndexForNodePart ::= K_FOR "(" Variable ")" K_ON_EACH_LABELS "(" Variable ")"
CreateLookupIndexForRelationshipPart ::= K_FOR "(" ")" "-" "[" Variable "]" "-" "(" ")" (K_ON_EACH_TYPE|K_ON_TYPE) "(" Variable ")"

CreateIndexOptionsPart ::= K_OPTIONS "{" LiteralEntry? ("," LiteralEntry)* "}"

DropIndex ::= K_DROP K_INDEX IndexName IfExists?

/*************************
 * Query
 */
Query ::= StandaloneCall | RegularQuery

//-- RegularQuery
RegularQuery ::= SingleQuery Union*
Union ::= K_UNION K_ALL? SingleQuery
SingleQuery ::= MultiPartQuery | SinglePartQuery

SinglePartQuery ::= ((ReadingClause* UpdatingClause+ Return?) | ReadingWithReturn)

ReadingWithReturn ::= ReadingClause* Return {pin=1 recoverWhile=statement_recover}

MultiPartQuery ::= ((ReadingClause* UpdatingClause* With)+ SinglePartQuery)

UpdatingClause ::= Create
               | Merge
               | Foreach
               | Delete
               | SetClause
               | Remove

ReadingClause ::= UseClause
              | LoadCSV
              | Start
              | Match
              | Unwind
              | CallSubQuery
              | InQueryCall

/*************************
 * Clauses
 */
//-- Use clause (Neo4j 4.0+): selects target graph/database
UseClause ::= K_USE (K_GRAPH Expression | Expression)

//-- Load csv
LoadCSV ::= K_LOAD K_CSV (K_WITH K_HEADERS)? K_FROM Expression K_AS Variable (K_FIELDTERMINATOR StringLiteral)?

//-- Start
Start ::= K_START (StartPoint ("," StartPoint)*)? Where?
StartPoint ::= Variable "=" Lookup
Lookup ::= NodeLookup | RelationshipLookup

NodeLookup ::= K_NODE (IdentifiedIndexLookup | IndexQuery | IdLookup)
RelationshipLookup ::= (K_RELATIONSHIP | K_REL) (IdentifiedIndexLookup | IndexQuery | IdLookup)

IdentifiedIndexLookup ::= ":" SymbolicNameString "(" SymbolicNameString "=" (StringLiteral | Parameter) ")"
IndexQuery ::= ":" SymbolicNameString "(" (StringLiteral | Parameter) ")"
IdLookup ::= "(" (LiteralIds | Parameter | "*") ")"
LiteralIds ::= IntegerLiteral ("," IntegerLiteral)*

//-- Match
Match ::= K_OPTIONAL? K_MATCH PatternWithWhereClause
PatternWithWhereClause ::= Pattern Hint* Where?
Hint ::= K_USING ((K_INDEX Variable NodeLabel "(" PropertyKeyName ")")
       | (K_JOIN K_ON Variable ("," Variable)*)
       | (K_SCAN Variable NodeLabel))

//-- Merge
Merge ::= K_MERGE PatternPart MergeAction*
MergeAction ::= K_ON (K_MATCH | K_CREATE) SetClause

//-- SetClause
SetClause ::= K_SET SetItem ("," SetItem)*
SetItem ::= (PropertyExpression "=" Expression)
          | (Variable "=" Expression)
          | (Variable "+=" Expression)
          | (Variable NodeLabels)

//-- Remove
Remove ::= K_REMOVE RemoveItem ("," RemoveItem)*
RemoveItem ::= (Variable NodeLabels) | PropertyExpression

//-- Return
With ::= K_WITH K_DISTINCT? ReturnBody Where?
Return ::= K_RETURN K_DISTINCT? ReturnBody
ReturnBody ::= ReturnItems Order? Skip? Limit?
ReturnItems ::= ("*" | ReturnItem) ("," ReturnItem)*
ReturnItem ::= (Expression K_AS Variable) | (Expression)
Order ::= K_ORDER K_BY SortItem ("," SortItem)*
SortItem ::= Expression (K_DESCENDING | K_DESC | K_ASCENDING | K_ASC)?
Skip ::= K_SKIP Expression
Limit ::= K_LIMIT Expression

//-- Call subquery
CallSubQuery ::= K_CALL "{" Query "}" SubqueryInTransactionsParameters? {pin=2}

SubqueryInTransactionsParameters ::= K_IN_TRANSACTIONS (SubqueryInTransactionsBatchParameters | SubqueryInTransactionsErrorParameters | SubqueryInTransactionsReportParameters)*
SubqueryInTransactionsBatchParameters ::= K_OF Expression (K_ROW | K_ROWS)
SubqueryInTransactionsErrorParameters ::= K_ON K_ERROR (K_CONTINUE | K_BREAK | K_FAIL)
SubqueryInTransactionsReportParameters ::= K_REPORT K_STATUS K_AS Variable

//-- Call procedure
Call ::= K_CALL ProcedureInvocation ProcedureResults?
InQueryCall ::= Call Where?
StandaloneCall ::= Call (Where? Return)?
ProcedureInvocation ::= ProcedureInvocationBody ProcedureArguments {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherProcedureInvocationImplMixin"
}
ProcedureInvocationBody ::= Namespace ProcedureName
ProcedureArguments ::= "(" Expression? ("," Expression)* ")" {
   implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherArgumentList"
}
ProcedureResults ::= K_YIELD ProcedureResult ("," ProcedureResult)*
ProcedureResult ::= AliasedProcedureResult | SimpleProcedureResult
AliasedProcedureResult ::= ProcedureOutput K_AS Variable
SimpleProcedureResult ::= Variable
ProcedureOutput ::= SymbolicNameString

//-- Other
Create ::= K_CREATE K_UNIQUE? Pattern
Delete ::= K_DETACH? K_DELETE Expression ("," Expression)*
Unwind ::= K_UNWIND Expression K_AS Variable
Foreach ::= K_FOREACH "(" Variable K_IN Expression "|" UpdatingClause+ ")"
Where ::= K_WHERE Expression

/*************************
 * Patterns
 */
Pattern ::= PatternPart ("," PatternPart)*
PatternPart ::= (Variable "=")? Selector? AnonymousPatternPart
AnonymousPatternPart ::= ShortestPathPattern | PatternElement
ShortestPathPattern ::= ShortestPathFunctionInvocation | AllShortestPathsFunctionInvocation {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherTypePropagator"
}
ShortestPathFunctionInvocation ::= (K_SHORTESTPATH "(" PatternElement ")") {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherPathYielding"
}
AllShortestPathsFunctionInvocation ::= (K_ALLSHORTESTPATHS "(" PatternElement ")") {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherListYielding"
}
PatternElement ::= ParenthesizedPath | (NodePattern PatternElementChain*)
PatternElementChain ::= RelationshipPattern Quantifier? NodePattern {pin=1}

RelationshipPattern ::= LeftArrowHead? Dash RelationshipDetail? Dash RightArrowHead? {pin=2}

RelationshipDetail ::= "[" Variable? "?"? LabelExpression? MaybeVariableLength? Properties? Where? "]" {pin=1}
RelationshipTypes ::= ":" RelTypeName ("|" ":"? RelTypeName)* {pin=1}
MaybeVariableLength ::= ("*" RangeLiteral?)

// Quantifier: fixed {n}, range {m,n}/{m,}/{,n}, or symbolic + and * (Neo4j 5+ GPM)
Quantifier ::= ("{" UnsignedInteger "}")
             | ("{" UnsignedInteger? "," UnsignedInteger? "}")
             | "+"
             | "*"

// ParenthesizedPath: ( Pattern WHERE? ) Quantifier?   (Neo4j 5+ GPM)
// No pin — must backtrack when inner Pattern fails (e.g. plain NodePattern)
ParenthesizedPath ::= "(" Pattern Where? ")" Quantifier?

// Selector: path selector for MATCH (ANY SHORTEST, ALL, SHORTEST n, etc.)
// PEG ordering: longer/more specific alternatives first to avoid premature match.
// ANY SHORTEST and ALL SHORTEST before ANY/ALL alone.
// SHORTEST+GROUP before SHORTEST+n (GROUP variant has optional integer).
Selector ::= (K_ANY K_SHORTEST (K_PATH | K_PATHS)?)
           | (K_ALL K_SHORTEST (K_PATH | K_PATHS)?)
           | (K_SHORTEST UnsignedInteger? (K_PATH | K_PATHS)? (K_GROUP | K_GROUPS))
           | (K_SHORTEST UnsignedInteger (K_PATH | K_PATHS)?)
           | (K_ANY UnsignedInteger? (K_PATH | K_PATHS)?)
           | (K_ALL (K_PATH | K_PATHS)?)

NodePattern ::= "(" Variable? LabelExpression? Properties? Where? ")" {pin=1}

RelationshipsPattern ::= NodePattern PatternElementChain+ {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherPathYielding"
}
Properties ::= MapLiteral | Parameter

/*************************
 * Label Expressions (Neo4j 5+)
 *
 * Two entry forms:
 *   Colon form:  :Person&Employee|Animal
 *   IS form:     IS Person&Employee|Animal
 *
 * Precedence (low → high): OR (|), AND (& or :), NOT (!), atoms
 *
 * The IS variants use SymbolicLabelNameString which excludes K_NOT and K_NULL
 * to prevent conflicts with IS NOT NULL / IS NULL in Expression3.
 * All inner rules are private (no pin) to allow PEG backtracking.
 */
LabelExpression ::= (":" LabelExpression4) | (K_IS LabelExpression4Is)

// Level 4: OR — lowest precedence
private LabelExpression4   ::= LabelExpression3   ("|" ":"? LabelExpression3)*
private LabelExpression4Is ::= LabelExpression3Is ("|" ":"? LabelExpression3Is)*

// Level 3: AND — & or : (legacy colon-conjunction)
private LabelExpression3   ::= LabelExpression2   ("&" LabelExpression2   | ":" LabelExpression2)*
private LabelExpression3Is ::= LabelExpression2Is ("&" LabelExpression2Is | ":" LabelExpression2Is)*

// Level 2: NOT — prefix
private LabelExpression2   ::= ("!" LabelExpression2)   | LabelExpression1
private LabelExpression2Is ::= ("!" LabelExpression2Is) | LabelExpression1Is

// Level 1: atoms — name, wildcard (%), parenthesized
// Colon form uses LabelName (→ SymbolicNameString) for PSI mixin compatibility
// IS form uses SymbolicLabelNameString (excludes K_NOT, K_NULL)
private LabelExpression1   ::= ("(" LabelExpression4   ")") | "%" | LabelName
private LabelExpression1Is ::= ("(" LabelExpression4Is ")") | "%" | SymbolicLabelNameString

/*************************
 * Expression
 */
Expression ::= Expression12 {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherTypePropagator"
}
private Expression12 ::= Expression11 (K_OR Expression11)*
private Expression11 ::= Expression10 (K_XOR Expression10)*
private Expression10 ::= Expression9 (K_AND Expression9)*
private Expression9 ::= (K_NOT Expression9) | Expression8
private Expression8 ::= Expression7 PartialComparisonExpression*
private PartialComparisonExpression ::= ("=" Expression7)
                                      | ("<>" Expression7)
                                      | ("!=" Expression7)
                                      | ("<" Expression7)
                                      | (">" Expression7)
                                      | ("<=" Expression7)
                                      | (">=" Expression7)
private Expression7 ::= Expression6 (("-" Expression6) | ("+" Expression6))*
private Expression6 ::= Expression5 (("*" Expression5) | ("/" Expression5) | ("%" Expression5))*
private Expression5 ::= Expression4 ("^" Expression4)*
private Expression4 ::= Expression3 | ("-" Expression4) | ("+" Expression4)
private Expression3 ::= Expression2 (
    ("[" Expression "]")
  | ("[" Expression? ".." Expression? "]")
  | ("=~" Expression2)
  | (K_IN Expression2)
  | (K_STARTS K_WITH  Expression2)
  | (K_ENDS K_WITH  Expression2)
  | (K_CONTAINS  Expression2)
  | (K_IS K_NULL)
  | (K_IS K_NOT K_NULL)
  | (K_IS K_NOT "::" CypherTypeName)
  | (K_IS K_NOT K_TYPED CypherTypeName)
  | (K_IS "::" CypherTypeName)
  | (K_IS K_TYPED CypherTypeName)
  | ("::" CypherTypeName)
)*
private Expression2 ::= Expression1 (PropertyLookup | LabelExpression)*
private Expression1 ::= UnaryOperator
              | NumberLiteral
              | StringLiteral
              | Parameter
              | BooleanLiteral
              | NullLiteral
              | CaseExpression
              | MapLiteral
              | MapProjection
              | CountStar
              | ListComprehension
              | PatternComprehension
              | Array

              | FilterFunctionInvocation
              | ExtractFunctionInvocation
              | ReduceFunctionInvocation
              | AllFunctionInvocation
              | AnyFunctionInvocation
              | NoneFunctionInvocation
              | SingleFunctionInvocation
              | ExistsFunctionInvocation

              | ShortestPathPattern
              | RelationshipsPattern
              | ParenthesizedExpression
              | FunctionInvocation
              | ExistentialSubQuery
              | CountSubQuery
              | CollectExpression
              | Variable


UnaryOperator ::= ("-" | "+") NumberLiteral {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherTypePropagator"
}

Array ::= ("[" Expression? ("," Expression)* "]") {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherListYielding"
}
PropertyLookup ::= "." PropertyKeyName
ListComprehension ::= "[" FilterExpression ("|"  Expression)? "]" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherListYielding"
}
FilterExpression ::= IdInColl Where?
IdInColl ::= Variable K_IN Expression
ParenthesizedExpression ::= "(" Expression ")" {
    pin=1
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherParenthesized"
}
FunctionInvocation ::= FunctionInvocationBody (("(" "*" ")") | FunctionArguments) {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherFunctionInvocationImplMixin"
}
FunctionArguments ::= "(" K_DISTINCT? Expression? ("," Expression)* ")" {
   implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherArgumentList"
}
FunctionInvocationBody ::= Namespace FunctionName

// Existential subquery: supports both full query form and pattern form (Neo4j 5+)
ExistentialSubQuery ::= K_EXISTS "{" (RegularQuery | K_MATCH? PatternWithWhereClause) "}"

// Count subquery: supports both full query form and pattern form (Neo4j 5+)
CountSubQuery ::= K_COUNT "{" (RegularQuery | K_MATCH? PatternWithWhereClause) "}"

// Collect subquery: COLLECT { query } → list (Neo4j 5+)
CollectExpression ::= K_COLLECT "{" RegularQuery "}"

CaseExpression ::= K_CASE ((CaseAlternatives+) | (Expression CaseAlternatives+))
                   (K_ELSE Expression)?
                   K_END {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherAnyYielding"
}
CaseAlternatives ::= K_WHEN Expression K_THEN Expression
PropertyExpression ::= Expression1 (PropertyLookup)+

FilterFunctionInvocation ::= K_FILTER "(" FilterExpression ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherFilterFunctionInvocationImplMixin"
}
ExtractFunctionInvocation ::= K_EXTRACT "(" FilterExpression ("|" Expression)? ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherExtractFunctionInvocationImplMixin"
}
ReduceFunctionInvocation ::= K_REDUCE "(" Variable "=" Expression "," IdInColl "|" Expression ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherReduceFunctionInvocationImplMixin"
}
AllFunctionInvocation ::= K_ALL "(" FilterExpression ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherAllFunctionInvocationImplMixin"
}
AnyFunctionInvocation ::= K_ANY "(" FilterExpression ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherAnyFunctionInvocationImplMixin"
}
NoneFunctionInvocation ::= K_NONE "(" FilterExpression ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherNoneFunctionInvocationImplMixin"
}
SingleFunctionInvocation ::= K_SINGLE "(" FilterExpression ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherSingleFunctionInvocationImplMixin"
}
ExistsFunctionInvocation ::= K_EXISTS "(" Expression ")" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherInvocation"
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherExistsFunctionInvocationImplMixin"
}

PatternComprehension ::= "[" RelationshipsPattern Where? "|" Expression "]" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherListYielding"
}

/*************************
 * Literals
 */
MapProjection ::= Variable "{" MapProjectionVariants? ("," MapProjectionVariants)* "}" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherMapYielding"
}
MapProjectionVariants ::= (LiteralEntry | PropertySelector | VariableSelector | AllPropertiesSelector)
LiteralEntry ::= PropertyKeyName ":" Expression
PropertySelector ::= "." Variable
VariableSelector ::= Variable
AllPropertiesSelector ::= "." "*"

/*************************
 * Literals
 */
Variable ::= SymbolicNameString {
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherVariableElementImplMixin"
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherVariableElement"
}
FunctionName ::= SymbolicNameString
ProcedureName ::= SymbolicNameString
CountStar ::= (K_COUNT "(" "*" ")") {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherIntegerYielding"
}
Parameter ::= NewParameter | OldParameter {
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherParameterImplMixin"
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherAnyYielding"
}
OldParameter ::= "{" (SymbolicNameString | UnsignedInteger) "}"
NewParameter ::= "$" (SymbolicNameString | UnsignedInteger)
NodeLabel ::= ":" LabelName
StringLiteral ::= l_string {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherStringYielding"
}
BooleanLiteral ::= K_TRUE | K_FALSE {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherBooleanYielding"
}
NullLiteral ::= K_NULL {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherNullYielding"
}
LabelName ::= SymbolicNameString {
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherLabelNameImplMixin"
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherNamedElement"
}
RelType ::= ":" RelTypeName
RelTypeName ::= SymbolicNameString {
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherRelTypeNameImplMixin"
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherNamedElement"
}
PropertyKeyName ::= SymbolicNameString {
    mixin="com.github.mdelambilly.graphdbplugin.language.cypher.psi.impl.CypherPropertyKeyNameImplMixin"
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.CypherNamedElement"
}

RangeLiteral ::= (IntegerLiteral? ".." IntegerLiteral?) | (IntegerLiteral)
MapLiteral ::= "{" (PropertyKeyName ":" Expression)? ("," PropertyKeyName ":" Expression)* "}" {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherMapYielding"
}
NodeLabels ::= NodeLabel+

NumberLiteral ::= DoubleLiteral | IntegerLiteral {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherTypePropagator"
}

DoubleLiteral ::= UnsignedDouble {// todo: make real double here
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherFloatYielding"
}

IntegerLiteral ::= UnsignedInteger {
    implements="com.github.mdelambilly.graphdbplugin.language.cypher.references.types.CypherIntegerYielding"
}

/*************************
 * Base
 */
Namespace ::= (SymbolicNameString ".")*
SymbolicNameString ::= UnescapedSymbolicNameString
    | EscapedSymbolicNameString
    | ReservedWord

ReservedWord ::= K_MATCH
                | K_YIELD
                | K_XOR
                | K_WITH
                | K_WHERE
                | K_WHEN
                | K_USING
                | K_UNWIND
                | K_UNIQUE
                | K_UNION
                | K_TRUE
                | K_THEN
                | K_STARTS
                | K_START
                | K_SKIP
                | K_SINGLE
                | K_SHORTESTPATH
                | K_SET
                | K_SCAN
                | K_SCALAR
                | K_RETURN
                | K_REQUIRE
                | K_REMOVE
                | K_RELATIONSHIP
                | K_REL
                | K_REDUCE
                | K_PROFILE
                | K_ORDER
                | K_OR
                | K_OPTIONAL
                | K_ON
                | K_OF
                | K_NULL
                | K_NOT
                | K_NONE
                | K_NODE
                | K_MERGE
                | K_MANDATORY
                | K_LOAD
                | K_LIMIT
                | K_JOIN
                | K_IS
                | K_INDEX
                | K_IN
                | K_HEADERS
                | K_FROM
                | K_FOREACH
                | K_FOR
                | K_FILTER
                | K_FIELDTERMINATOR
                | K_FALSE
                | K_EXTRACT
                | K_EXPLAIN
                | K_EXISTS
                | K_ENDS
                | K_END
                | K_ELSE
                | K_DROP
                | K_DO
                | K_DISTINCT
                | K_DETACH
                | K_DESCENDING
                | K_DESC
                | K_DELETE
                | K_CYPHER
                | K_CSV
                | K_CREATE
                | K_COUNT
                | K_CONTAINS
                | K_CONSTRAINT
                | K_COMMIT
                | K_CASE
                | K_CALL
                | K_BY
                | K_BEGIN
                | K_ASSERT
                | K_ASCENDING
                | K_ASC
                | K_AS
                | K_ANY
                | K_AND
                | K_ALLSHORTESTPATHS
                | K_ALL
                | K_ADD
                // Phase 1: new keywords for admin commands
                | K_ACCESS
                | K_ACTIVE
                | K_ADMIN
                | K_ADMINISTRATOR
                | K_ALTER
                | K_ASSIGN
                | K_BOOSTED
                | K_BRIEF
                | K_BTREE
                | K_CATALOG
                | K_CHANGE
                | K_COLLECT
                | K_CONSTRAINTS
                | K_COPY
                | K_CURRENT
                | K_DATABASE
                | K_DATABASES
                | K_DBMS
                | K_DEFAULT
                | K_DEFINED
                | K_DENY
                | K_ELEMENT
                | K_ELEMENTS
                | K_EXECUTE
                | K_EXIST
                | K_FUNCTION
                | K_FUNCTIONS
                | K_GRANT
                | K_GRAPH
                | K_GRAPHS
                | K_IF
                | K_INDEXES
                | K_KEY
                | K_LABEL
                | K_LABELS
                | K_MANAGEMENT
                | K_NAME
                | K_NAMES
                | K_NEW
                | K_NODES
                | K_OUTPUT
                | K_PASSWORD
                | K_POPULATED
                | K_PRIVILEGE
                | K_PRIVILEGES
                | K_PROCEDURE
                | K_PROCEDURES
                | K_PROPERTY
                | K_READ
                | K_RELATIONSHIPS
                | K_REPLACE
                | K_REQUIRED
                | K_REVOKE
                | K_ROLE
                | K_ROLES
                | K_SHOW
                | K_STATUS
                | K_STOP
                | K_SUSPENDED
                | K_TO
                | K_TRANSACTION
                | K_TRANSACTIONS
                | K_TRAVERSE
                | K_TYPE
                | K_TYPED
                | K_TYPES
                | K_USE
                | K_USER
                | K_USERS
                | K_VERBOSE
                | K_WRITE
                // Phase G2: GPM path selectors
                | K_SHORTEST
                | K_PATHS
                | K_PATH
                | K_GROUPS
                | K_GROUP
                // Phase H: full privilege model
                | K_ALIAS
                | K_COMPOSITE
                | K_HOME
                | K_IMMUTABLE
