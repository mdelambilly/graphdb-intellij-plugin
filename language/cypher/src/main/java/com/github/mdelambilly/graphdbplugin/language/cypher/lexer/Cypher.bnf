                | K_OPTION
                | K_AT
                | K_ALIASES
                // Phase J: extended subquery IN TRANSACTIONS
                | K_CONTINUE
                | K_BREAK
                | K_FAIL
                | K_REPORT
                | K_ROW
                | K_ROWS
                | K_ERROR
                // Phase K: server management and rename/terminate commands
                | K_ENABLE
                | K_DRYRUN
                | K_DEALLOCATE
                | K_REALLOCATE

// Used in IS label expressions — excludes K_NOT and K_NULL to avoid
// ambiguity with IS NOT NULL / IS NULL in Expression3.
// Excludes K_NOT_NULL compound token (not in this grammar) but safe to list.
SymbolicLabelNameString ::= UnescapedSymbolicNameString
    | EscapedSymbolicNameString
    | LabelReservedWord

LabelReservedWord ::= K_MATCH
                | K_YIELD
                | K_XOR
                | K_WITH
                | K_WHERE
                | K_WHEN
                | K_USING
                | K_UNWIND
                | K_UNIQUE
                | K_UNION
                | K_TRUE
                | K_THEN
                | K_STARTS
                | K_START
                | K_SKIP
                | K_SINGLE
                | K_SHORTESTPATH
                | K_SET
                | K_SCAN
                | K_SCALAR
                | K_RETURN
                | K_REQUIRE
                | K_REMOVE
                | K_RELATIONSHIP
                | K_REL
                | K_REDUCE
                | K_PROFILE
                | K_ORDER
                | K_OR
                | K_OPTIONAL
                | K_ON
                | K_OF
                // K_NULL intentionally excluded
                // K_NOT intentionally excluded
                | K_NONE
                | K_NODE
                | K_MERGE
                | K_MANDATORY
                | K_LOAD
                | K_LIMIT
                | K_JOIN
                | K_IS
                | K_INDEX
                | K_IN
                | K_HEADERS
                | K_FROM
                | K_FOREACH
                | K_FOR
                | K_FILTER
                | K_FIELDTERMINATOR
                | K_FALSE
                | K_EXTRACT
                | K_EXPLAIN
